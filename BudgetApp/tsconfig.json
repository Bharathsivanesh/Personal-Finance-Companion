{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "app/index.tsx",   //IMPORTANT
    "nativewind-env.d.ts"
, "app/(auth)/login.jsx", "app/(auth)/signup.jsx", "src/components/ui/Loader.jsx", "src/components/ui/Toast.jsx"  ]
}